# Example local email secrets for github-usage.
# Copy to .env.email-report and fill in real values, or run: ./setup.sh
#
# Do not commit .env.email-report (it is gitignored).

export GITHUB_TOKEN="ghp_your_token_with_user_scope"
export RESEND_API_KEY="re_your_resend_api_key"
export REPORT_EMAIL="you@example.com"
export RESEND_FROM="reports@your-verified-domain.example"

# Optional:
# export REPORT_SUBJECT="Custom subject line"
