    print()
    print(f"  Actions Storage (avg):")
    print(f"    Used:         {avg_storage_mb:>8.1f} / {storage_limit} MB")
    print(f"    Remaining:    {storage_remaining:>8.1f} MB ({storage_pct:.1f}% used)")
