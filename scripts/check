#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "==> Python syntax"
python3 -m py_compile github-usage src/github_usage/*.py

echo "==> Unit tests"
PYTHONPATH=src python3 -m unittest discover -s tests -v

echo "==> CLI smoke"
PYTHONPATH=src python3 -m github_usage --help >/dev/null
SMOKE_HOME="$(mktemp -d)"
env -u GITHUB_TOKEN HOME="$SMOKE_HOME" PATH="/usr/bin:/bin:/usr/sbin:/sbin" PYTHONPATH=src python3 -m github_usage >/tmp/github-usage-smoke.out 2>&1 && {
  cat /tmp/github-usage-smoke.out
  echo "Expected no-token smoke command to fail"
  exit 1
}
grep -q "No GitHub token found" /tmp/github-usage-smoke.out

echo "check passed"
