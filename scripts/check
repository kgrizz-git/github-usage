#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "==> Python syntax"
scripts/python -m py_compile github-usage src/github_usage/*.py

echo "==> Unit tests"
PYTHONPATH=src scripts/python -m unittest discover -s tests -v

echo "==> CLI smoke"
PYTHONPATH=src scripts/python -m github_usage --help >/dev/null
SMOKE_HOME="$(mktemp -d)"
env -u GITHUB_TOKEN HOME="$SMOKE_HOME" PYTHONPATH=src .venv/bin/python -m github_usage >/tmp/github-usage-smoke.out 2>&1 && {
  cat /tmp/github-usage-smoke.out
  echo "Expected no-token smoke command to fail"
  exit 1
}
grep -q "No GitHub token found" /tmp/github-usage-smoke.out

echo "==> Size check"
scripts/python scripts/check-sizes

echo "check passed"
